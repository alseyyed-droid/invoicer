generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "mysql"
}

model User {
  id             String          @id @default(cuid()) @db.VarChar(191)
  name           String?         @db.VarChar(191)
  email          String?         @unique @db.VarChar(191)
  emailVerified  DateTime?
  password       String?         @db.VarChar(255)
  image          String?         @db.VarChar(500)
  mobileNumber   String?         @db.VarChar(50)
  locale         String          @default("en") @db.VarChar(10)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  companyInfo    CompanyInfo?
  preferences    UserPreferences?
  invoices       Invoice[]
  items          Item[]
  taxTypes       TaxType[]
}

model CompanyInfo {
  id           String   @id @default(cuid()) @db.VarChar(191)
  userId       String   @unique @db.VarChar(191)
  companyName  String?  @db.VarChar(191)
  country      String?  @db.VarChar(100)
  city         String?  @db.VarChar(100)
  companyEmail String?  @db.VarChar(191)
  address      String?  @db.Text
  postalCode   String?  @db.VarChar(50)
  companyLogo  String?  @db.LongText
  taxPerItem   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id                  String   @id @default(cuid()) @db.VarChar(191)
  userId              String   @unique @db.VarChar(191)
  language            String   @default("en") @db.VarChar(10)
  currency            String   @default("USD") @db.VarChar(10)
  dateFormat          String   @default("DD/MM/YYYY") @db.VarChar(20)
  timeZone            String   @default("Asia/Amman") @db.VarChar(100)
  fiscalYear          String   @default("January - December") @db.VarChar(50)
  timeFormat          String   @default("24h") @db.VarChar(10)
  invoicePrefix       String   @default("INV") @db.VarChar(20)
  invoiceSeparator    String   @default("-") @db.VarChar(10)
  invoiceNumberLength Int      @default(6)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid()) @db.VarChar(191)
  userId            String  @db.VarChar(191)
  type              String  @db.VarChar(32)
  provider          String  @db.VarChar(32)
  providerAccountId String  @db.VarChar(96)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(32)
  scope             String? @db.VarChar(191)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(96)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @db.VarChar(191)
  sessionToken String   @unique @db.VarChar(96)
  userId       String   @db.VarChar(191)
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String   @db.VarChar(96)
  token      String   @unique @db.VarChar(96)
  expires    DateTime

  @@unique([identifier, token])
}

model Invoice {
  id            String        @id @default(cuid()) @db.VarChar(191)
  number        String        @unique @db.VarChar(64)
  shareToken    String?       @unique @db.VarChar(191)
  customerName  String        @db.VarChar(191)
  customerEmail String        @db.VarChar(191)
  invoiceDate   DateTime
  notes         String?       @db.Text
  templateId    String        @default("minimalist") @db.VarChar(50)
  discountType  InvoiceDiscountType @default(FIXED)
  discountValue Float         @default(0)
  discountAmount Float        @default(0)
  subtotal      Float         @default(0)
  taxTotal      Float         @default(0)
  grandTotal    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  locale        String        @default("en") @db.VarChar(10)
  userId        String        @db.VarChar(191)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems     InvoiceLine[]
}

model InvoiceLine {
  id        String   @id @default(cuid()) @db.VarChar(191)
  invoiceId String   @db.VarChar(191)
  name      String   @db.VarChar(191)
  quantity  Int      @default(1)
  price     Float
  taxRate   Float    @default(0)
  lineTotal Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxes     InvoiceLineTax[]
}

model InvoiceLineTax {
  id        String   @id @default(cuid()) @db.VarChar(191)
  lineItemId String  @db.VarChar(191)
  taxTypeId String?  @db.VarChar(191)
  title     String   @db.VarChar(191)
  percentage Float
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lineItem  InvoiceLine @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  taxType   TaxType? @relation(fields: [taxTypeId], references: [id], onDelete: SetNull)
}

model Item {
  id          String   @id @default(cuid()) @db.VarChar(191)
  name        String   @db.VarChar(191)
  description String?  @db.Text
  price       Float
  unitType    String   @db.VarChar(50)
  userId      String   @db.VarChar(191)
  taxTypeId   String?  @db.VarChar(191)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxType     TaxType? @relation(fields: [taxTypeId], references: [id], onDelete: SetNull)
}

model TaxType {
  id          String   @id @default(cuid()) @db.VarChar(191)
  title       String   @db.VarChar(191)
  percentage  Float
  description String?  @db.Text
  userId      String   @db.VarChar(191)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       Item[]
  invoiceLineTaxes InvoiceLineTax[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum InvoiceDiscountType {
  PERCENTAGE
  FIXED
}
